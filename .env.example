# Copy these into Hostinger → Node.js → Environment variables
# Do NOT commit real secrets to GitHub.

NODE_ENV=production
# Hostinger usually sets PORT automatically — do not hardcode if the panel provides it
# PORT=3000

DATABASE_URL=mysql://USER:PASSWORD@HOST:3306/DATABASE_NAME?connection_limit=5
USER_FRONTEND_URL=https://halodirect.io
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=60m
JWT_ACCESS_EXPIRES_IN=1d

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
